@startuml Add to Cart Sequence Diagram

actor User
participant "CartController" as CC
participant "CartService" as CS
participant "UserRepository" as UR
participant "BookRepository" as BR
participant "CartItemRepository" as CIR

User -> CC : POST /api/cart/items/{bookId}
CC -> CS : addToCart(email, bookId)
CS -> UR : findByEmail(email)

CS -> BR : findById(bookId)

alt Book not found
  CS --> CC : 404 "Book not found"
  CC --> User : 404 Error
end

alt Book stock <= 0
  CS --> CC : 400 "Book is out of stock"
  CC --> User : 400 Error
end

CS -> CIR : existsByUserIdAndBookId(userId, bookId)

alt Book already in cart
  CS --> CC : 409 "Book is already in your cart"
  CC --> User : 409 Conflict
end

CS -> CIR : save(cartItem)
CIR --> CS : CartItem
CS --> CC : CartItemResponse
CC --> User : 201 Created + CartItem

@enduml
