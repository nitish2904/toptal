@startuml Checkout Sequence Diagram

actor User
participant "CartController" as CC
participant "CartService" as CS
participant "UserRepository" as UR
participant "CartItemRepository" as CIR
participant "BookRepository" as BR
participant "OrderRepository" as OR

User -> CC : POST /api/cart/checkout
CC -> CS : checkout(email)

note over CS : synchronized block begins

CS -> UR : findByEmail(email)
CS -> CIR : findByUserId(userId)
CIR --> CS : List<CartItem>

alt Cart is empty
  CS --> CC : 400 Bad Request "Cart is empty"
  CC --> User : 400 Error Response
end

loop For each CartItem
  CS -> BR : findById(bookId)
  BR --> CS : Book

  alt Book stock <= 0
    CS --> CC : 400 "Book no longer in stock"
    CC --> User : 400 Error Response
  end

  CS -> CS : Decrement book.stock
  CS -> BR : save(book)
end

CS -> OR : save(order)
CS -> CIR : deleteByUserId(userId)

note over CS : synchronized block ends

OR --> CS : Order
CS --> CC : OrderResponse
CC --> User : 200 OK + Order Details

@enduml
