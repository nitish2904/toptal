@startuml Architecture - Component Diagram
skinparam componentStyle rectangle

package "Client Layer" {
  [REST Client / Browser] as CLIENT
}

package "Spring Boot Application" {
  package "Controller Layer" {
    [AuthController] as AC
    [BookController] as BC
    [CategoryController] as CC
    [AdminController] as ADC
    [CartController] as CTC
    [OrderController] as OC
  }

  package "Security Layer" {
    [JwtAuthenticationFilter] as SF
    [JwtService] as JS
    [SecurityConfig] as SC
    [CustomUserDetailsService] as CUDS
  }

  package "Service Layer" {
    [AuthService] as AS
    [BookService] as BS
    [CategoryService] as CS
    [CartService] as CTS
    [CartExpiryScheduler] as CES
  }

  package "Repository Layer\n(ConcurrentHashMap-backed)" {
    [UserRepository] as UR
    [CategoryRepository] as CR
    [BookRepository] as BR
    [CartItemRepository] as CIR
    [OrderRepository] as OR
  }
}

CLIENT --> SF : HTTP Requests
SF --> JS : Validate JWT
SF --> CUDS : Load User
SF --> AC : Authorized
SF --> BC
SF --> CC
SF --> ADC
SF --> CTC
SF --> OC

AC --> AS
BC --> BS
CC --> CS
ADC --> BS
ADC --> CS
CTC --> CTS
OC --> CTS

AS --> UR
BS --> BR
BS --> CR
CS --> CR
CS --> BR
CTS --> UR
CTS --> BR
CTS --> CIR
CTS --> OR
CES --> CIR : Every 10 min
CUDS --> UR

@enduml
